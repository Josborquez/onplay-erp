// Bloque 1 — modelo de identidad del staff del ERP Onplay.
// Stack fijo (CLAUDE.md B5): Prisma + MySQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Los 4 roles de staff de la fundación (00-fundacion.md §4.1).
enum Role {
  SUPER_ADMIN
  STORE_ADMIN
  ACCOUNTANT
  SALES_ASSISTANT
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  role         Role
  passwordHash String? // null = usuario solo-Google (sin clave local)
  pinHash      String // PIN único por persona (R6), siempre presente
  googleSub    String?  @unique // subject de Google, null hasta el primer login Google
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions  Session[]
  auditLogs AuditLog[]

  // Inventario (2B): quién creó cada reserva y cada movimiento de stock.
  reservations Reservation[]
  movements    StockMovement[]

  // Importaciones (2C): quién corrió cada lote de carga ManaBox.
  importBatches ImportBatch[]

  // POS (bloque 3): cajas que abrió/cerró y ventas que operó/anuló.
  cashSessionsOpened CashSession[] @relation("CashSessionOpenedBy")
  cashSessionsClosed CashSession[] @relation("CashSessionClosedBy")
  sales              Sale[]        @relation("SaleOperator")
  salesVoided        Sale[]        @relation("SaleVoidedBy")
}

model Session {
  id                String    @id @default(uuid())
  userId            Int
  user              User      @relation(fields: [userId], references: [id])
  createdAt         DateTime  @default(now())
  absoluteExpiresAt DateTime // expiración dura de la sesión (R3, server-side)
  lastActivityAt    DateTime  @default(now()) // base del contador de inactividad
  revokedAt         DateTime? // logout / re-login → sesión muerta

  @@index([userId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String // LOGIN, LOGIN_GOOGLE, LOGOUT, UNLOCK, LOGIN_FAILED, ...
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ───────────────────────────────────────────────────────────────────
// Bloque 2 — Catálogo (sub-tanda 2A). Inventario (StockUnit, Reserva,
// movimientos) llega en 2B; aquí solo el catálogo y la tabla Settings.
// ───────────────────────────────────────────────────────────────────

// Las 4 categorías de producto (bloque-2 §2).
enum ProductType {
  SINGLE
  SEALED
  SNACK
  ACCESSORY
}

// Cómo se rastrea el stock de un producto (bloque-2 §2.2):
// UNIDAD = una fila por carta (singles); CANTIDAD = contadores (resto).
enum TrackingMode {
  UNIDAD
  CANTIDAD
}

model Game {
  id                   Int       @id @default(autoincrement())
  name                 String    @unique
  referencePriceSource String // CardKingdom (MTG), TCGPlayer (One Piece, …)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  products             Product[]
}

model Product {
  id           Int          @id @default(autoincrement())
  type         ProductType
  trackingMode TrackingMode
  name         String
  sku          String?      @unique // singles: SET-num-COND-LANG; resto opcional
  gameId       Int?
  game         Game?        @relation(fields: [gameId], references: [id])
  isActive     Boolean      @default(true)

  // Costo y precio en CLP (enteros: el peso chileno no tiene decimales).
  // margen = precio − costo se calcula al leer; no se persiste.
  costo  Int?
  precio Int?

  // Precio de referencia en USD (singles): base del precio sugerido de venta.
  referencePrice Decimal? @db.Decimal(10, 2)

  // Atributos extra de un single (bloque-2 §3); null para el resto.
  setCode         String?
  setName         String?
  collectorNumber String?
  foil            Boolean?
  rarity          String?
  condition       String?
  language        String?
  scryfallId      String?
  misprint        Boolean?
  altered         Boolean?
  imageUrl        String? // URL de Scryfall derivada en el import (2C)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Inventario (2B): unidades/niveles, reservas y movimientos de este producto.
  stockUnits   StockUnit[]
  stockLevels  StockLevel[]
  reservations Reservation[]
  movements    StockMovement[]

  // POS (bloque 3): líneas de venta que referencian este producto.
  saleLines SaleLine[]

  @@index([gameId])
}

// Parámetros de negocio editables en runtime (bloque-2 §5.3).
// Clave-valor: el valor se guarda como texto y se parsea al leer.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────────
// Bloque 2B — Motor de inventario. Dos modos de rastreo (UNIDAD/CANTIDAD)
// y el contrato reservar → (confirmar | liberar) bajo candado de fila.
// ───────────────────────────────────────────────────────────────────

// Estado de una unidad física (modo UNIDAD, singles).
enum StockUnitState {
  DISPONIBLE
  RESERVADA
  VENDIDA
}

// Estado del ciclo de vida de una reserva.
// ANULADA (bloque 3): una reserva CONFIRMADA cuya venta se anuló intra-sesión;
// su stock volvió a DISPONIBLE por la reversa acotada (Opción A §3).
enum ReservationState {
  ACTIVA
  CONFIRMADA
  LIBERADA
  EXPIRADA
  ANULADA
}

// Tipo de movimiento físico de stock (entradas/salidas reales).
// ANULACION (bloque 3): movimiento compensatorio al anular una venta; revierte
// una SALIDA previa devolviendo la unidad/cantidad a DISPONIBLE (no borra nada).
enum StockMovementType {
  ENTRADA
  SALIDA
  AJUSTE
  TRANSFERENCIA
  ANULACION
}

// Ubicación física del stock. 2B opera solo sobre `tienda`; las ferias se
// modelan aquí para el futuro (sin endpoint de transferencia todavía).
model Location {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  stockUnits   StockUnit[]
  stockLevels  StockLevel[]
  reservations Reservation[]
  movements    StockMovement[]
}

// Modo UNIDAD (singles): una fila por carta.
model StockUnit {
  id            Int            @id @default(autoincrement())
  productId     Int
  product       Product        @relation(fields: [productId], references: [id])
  locationId    Int
  location      Location       @relation(fields: [locationId], references: [id])
  state         StockUnitState @default(DISPONIBLE)
  reservationId Int?
  reservation   Reservation?   @relation(fields: [reservationId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // POS (bloque 3): líneas de venta que vendieron esta unidad física. Es una
  // lista porque una unidad anulada y revendida puede aparecer en más de una.
  saleLines SaleLine[]

  @@index([productId, locationId, state])
  @@index([reservationId])
}

// Modo CANTIDAD (sellado, snack, accesorio): contadores por producto/ubicación.
model StockLevel {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  locationId Int
  location   Location @relation(fields: [locationId], references: [id])
  available  Int      @default(0)
  reserved   Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([productId, locationId])
}

// Reserva: audita el ciclo reservar → (confirmar | liberar | expirar).
model Reservation {
  id          Int              @id @default(autoincrement())
  productId   Int
  product     Product          @relation(fields: [productId], references: [id])
  locationId  Int
  location    Location         @relation(fields: [locationId], references: [id])
  quantity    Int
  state       ReservationState @default(ACTIVA)
  expiresAt   DateTime
  createdById Int?
  createdBy   User?            @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  units StockUnit[]

  // POS (bloque 3): la línea de venta que respalda esta reserva (1:1).
  saleLine SaleLine?

  @@index([state, expiresAt])
}

// Movimiento físico de stock: ENTRADA (carga) y SALIDA (venta confirmada).
// Reservar/liberar NO generan movimiento (no cambia el stock físico).
model StockMovement {
  id         Int               @id @default(autoincrement())
  productId  Int
  product    Product           @relation(fields: [productId], references: [id])
  locationId Int
  location   Location          @relation(fields: [locationId], references: [id])
  type       StockMovementType
  quantity   Int
  userId     Int?
  user       User?             @relation(fields: [userId], references: [id])
  detail     String?
  createdAt  DateTime          @default(now())

  @@index([productId])
}

// ───────────────────────────────────────────────────────────────────
// Bloque 2C — Importación ManaBox. Cada lote (archivo CSV) se identifica
// por el hash de su contenido para que reimportar el mismo lote no
// duplique stock (idempotencia, bloque-2 §6).
// ───────────────────────────────────────────────────────────────────
model ImportBatch {
  id          Int      @id @default(autoincrement())
  source      String // "MANABOX"
  hash        String   @unique // SHA-256 del contenido del CSV
  rowCount    Int
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

// ───────────────────────────────────────────────────────────────────
// Bloque 3 — Canal POS. El POS es un canal hijo: nunca escribe stock
// directamente, todo pasa por el motor del bloque 2. Montos en CLP entero.
// El cliente (cliente_id) se difiere al bloque 4 (wallet). La auditoría
// reusa AuditLog (bloque 1), no hay tabla propia.
// ───────────────────────────────────────────────────────────────────

enum CashSessionState {
  ABIERTA
  CERRADA
}

enum SaleState {
  BORRADOR
  COMPLETADA
  ANULADA
  ABANDONADA
}

// STORE_CREDIT queda reservado pero deshabilitado hasta el wallet (bloque 4).
enum PaymentMethod {
  CASH
  DEBIT
  CREDIT
  TRANSFER
  STORE_CREDIT
}

// Punto de venta físico (mostrador, caja de eventos, …).
model Terminal {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  sessions  CashSession[]
}

// Sesión de caja: apertura/cierre con cuadre (esperado vs. contado).
// Invariante: como máximo una sesión ABIERTA por terminal (guard transaccional
// en el servicio; MySQL no soporta índice único parcial).
model CashSession {
  id             Int              @id @default(autoincrement())
  terminalId     Int
  terminal       Terminal         @relation(fields: [terminalId], references: [id])
  openedById     Int
  openedBy       User             @relation("CashSessionOpenedBy", fields: [openedById], references: [id])
  openingFloat   Int // efectivo inicial declarado (CLP)
  openedAt       DateTime         @default(now())
  state          CashSessionState @default(ABIERTA)
  closedAt       DateTime?
  closedById     Int?
  closedBy       User?            @relation("CashSessionClosedBy", fields: [closedById], references: [id])
  expectedAmount Int? // fondo + Σ pagos CASH (calculado al cerrar)
  countedAmount  Int? // efectivo contado al cerrar
  difference     Int? // contado − esperado
  notes          String?          @db.Text

  sales Sale[]

  @@index([terminalId, state])
}

// Venta del mostrador. El folio es correlativo sin huecos, generado bajo lock
// en el checkout. subtotal/descuento/total en CLP entero.
model Sale {
  id            Int       @id @default(autoincrement())
  folio         Int?      @unique // se asigna en el checkout (COMPLETADA)
  cashSessionId Int
  cashSession   CashSession @relation(fields: [cashSessionId], references: [id])
  userId        Int
  user          User      @relation("SaleOperator", fields: [userId], references: [id])
  state         SaleState @default(BORRADOR)
  subtotal      Int       @default(0) // suma de líneas antes del descuento de total
  totalDiscount Int       @default(0) // descuento aplicado al total
  total         Int       @default(0) // a cobrar
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  voidedAt      DateTime?
  voidedById    Int?
  voidedBy      User?     @relation("SaleVoidedBy", fields: [voidedById], references: [id])
  voidReason    String?   @db.Text

  // Wallet (bloque 4B): cliente asociado a la venta (opcional; obligatorio solo
  // si se paga con STORE_CREDIT). Se difería al bloque 4 (ver §3 bloque 3).
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  lines           SaleLine[]
  payments        Payment[]
  walletMovements WalletMovement[]

  @@index([cashSessionId])
}

// Línea de venta. Cada línea se respalda en exactamente una reserva viva del
// bloque 2 (1:1). Singles: cantidad 1 y unidad física identificada; CANTIDAD: N.
model SaleLine {
  id            Int          @id @default(autoincrement())
  saleId        Int
  sale          Sale         @relation(fields: [saleId], references: [id])
  reservationId Int          @unique
  reservation   Reservation  @relation(fields: [reservationId], references: [id])
  productId     Int
  product       Product      @relation(fields: [productId], references: [id])
  stockUnitId   Int? // solo singles (tracking por unidad)
  stockUnit     StockUnit?   @relation(fields: [stockUnitId], references: [id])
  sku           String? // snapshot
  description   String // snapshot
  trackingMode  TrackingMode
  quantity      Int
  unitPrice     Int // snapshot del precio al agregar la línea (CLP)
  lineDiscount  Int          @default(0)
  lineTotal     Int

  @@index([saleId])
}

// Contador atómico de secuencias (bloque 3). Hoy lo usa el folio correlativo
// sin huecos del POS. El incremento se hace con INSERT … ON DUPLICATE KEY UPDATE
// (toma candado de fila) dentro de la transacción del checkout: si esta hace
// rollback, el folio también se revierte y no quedan huecos.
model Counter {
  name  String @id
  value Int    @default(0)
}

// Pago aplicado a una venta. `amount` es el monto aplicado (no el recibido):
// el exceso de efectivo es vuelto y no se persiste. Pago mixto = varias filas.
model Payment {
  id        Int           @id @default(autoincrement())
  saleId    Int
  sale      Sale          @relation(fields: [saleId], references: [id])
  method    PaymentMethod
  amount    Int // CLP entero
  reference String? // últimos dígitos, nro. de transferencia, etc.
  createdAt DateTime      @default(now())

  // Wallet (bloque 4B): cuando method = STORE_CREDIT apunta al movimiento de
  // débito que respalda este pago (trazabilidad 1:1). null para los demás.
  walletMovementId Int?            @unique
  walletMovement   WalletMovement? @relation(fields: [walletMovementId], references: [id])

  @@index([saleId])
}

// ───────────────────────────────────────────────────────────────────
// Bloque 4 — Wallet del cliente (saldo de tienda). Sub-tanda 4A: motor de
// wallet autoritativo, sin tocar el POS. El cableado con el checkout/anulación
// (STORE_CREDIT, Payment.walletMovementId, Sale.customerId) llega en 4B.
// Reusa el patrón del 2B: saldo cacheado + ledger inmutable bajo candado de
// fila. Dinero en CLP entero.
// ───────────────────────────────────────────────────────────────────

enum WalletMovementType {
  CREDITO_MANUAL // + recarga/carga histórica registrada por staff
  DEBITO_VENTA // - pago de una venta POS con store credit
  REVERSA_VENTA // + devolución de saldo al anular una venta
  AJUSTE // ± corrección manual (admin + PIN); el signo lo decide el operador
  EXPIRACION // - vencimiento de crédito (hook §6, barrido diferido)
}

// Población de clientes, separada del User de staff (bloque 1). Un cliente de
// mostrador puede existir con solo nombre+teléfono; rut/email son opcionales
// pero únicos si existen. activo = soft-disable (nunca borra saldo ni historial).
model Customer {
  id        Int      @id @default(autoincrement())
  rut       String?  @unique
  nombre    String
  email     String?  @unique
  telefono  String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet      WalletAccount?
  movimientos WalletMovement[]
  ventas      Sale[] // ventas POS asociadas (bloque 4B)

  @@index([nombre])
}

// Una cuenta por cliente. `saldo` es el cache que se bloquea con FOR UPDATE; la
// verdad es la suma del ledger. Se crea junto con el Customer (saldo 0, D4-03).
model WalletAccount {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id])
  saldo      Int      @default(0) // CLP entero; invariante: == suma del ledger, >= 0
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Ledger inmutable: cada cambio de saldo es una fila, nunca se edita ni se
// borra. Una corrección es un movimiento nuevo (AJUSTE). `monto` siempre
// positivo; el signo lo da `tipo`. Idempotencia por `reference` (@unique).
// saleId y performedBy quedan como Int plano en 4A (la relación a Sale y la
// trazabilidad pago↔movimiento se cablean en 4B).
model WalletMovement {
  id           Int                @id @default(autoincrement())
  customerId   Int
  customer     Customer           @relation(fields: [customerId], references: [id])
  tipo         WalletMovementType
  monto        Int // CLP entero, SIEMPRE positivo
  saldoAntes   Int
  saldoDespues Int
  reference    String             @unique // misma reference => 409, no se duplica
  origen       String // POS_VENTA | MANUAL | ANULACION | AJUSTE | EXPIRACION
  motivo       String? // texto libre (obligatorio en AJUSTE)
  expiraEn     DateTime? // solo créditos; null = no expira (hook §6)
  saleId       Int? // FK a Sale cuando viene del POS (bloque 4B)
  sale         Sale?              @relation(fields: [saleId], references: [id])
  performedBy  Int // userId del staff que ejecutó (de la sesión)
  createdAt    DateTime           @default(now())

  // Wallet↔Pago (bloque 4B): el Payment STORE_CREDIT que respalda este débito.
  payment Payment?

  @@index([customerId, createdAt])
  @@index([reference])
  @@index([expiraEn])
}
