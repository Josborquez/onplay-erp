# Base de datos (producción / desarrollo)
DATABASE_URL="mysql://usuario:clave@localhost:3306/onplay_erp"

# Base de datos para los tests (Vitest). Debe ser una BD distinta y desechable.
TEST_DATABASE_URL="mysql://usuario:clave@localhost:3306/onplay_erp_test"

# Secreto del JWT. DEBE tener al menos 32 caracteres (validado al arranque).
JWT_SECRET="cambia-esto-por-un-secreto-largo-de-al-menos-32-caracteres"

# Vida absoluta de la sesión y umbral de inactividad (en minutos).
SESSION_ABSOLUTE_HOURS=12
INACTIVITY_MINUTES=10

# Google OAuth — Client ID real del proyecto (para el login Google de producción).
GOOGLE_CLIENT_ID="xxxxxxxxxxxx.apps.googleusercontent.com"

# CORS whitelist (orígenes permitidos, separados por coma).
CORS_ORIGINS="http://localhost:5173"

# Puerto del servidor.
PORT=3000

# Seed del primer Super admin sistema.
SEED_ADMIN_EMAIL="admin@onplaygames.cl"
SEED_ADMIN_NAME="Super Admin"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
SEED_ADMIN_PIN="1234"

# Seed opcional de un Sales assistant (para probar la guarda por rol / 403).
SEED_SALES_EMAIL="vendedor@onplaygames.cl"
SEED_SALES_NAME="Vendedor Demo"
SEED_SALES_PASSWORD="ChangeMe!2026"
SEED_SALES_PIN="5678"
