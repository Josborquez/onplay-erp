# URL base del backend del ERP.
VITE_API_URL=http://localhost:3000

# Client ID de Google OAuth — el mismo que usa el backend.
VITE_GOOGLE_CLIENT_ID=575566628730-...apps.googleusercontent.com

# Umbral de inactividad (minutos). Debe coincidir con INACTIVITY_MINUTES del backend.
VITE_INACTIVITY_MINUTES=10

# Segundos de aviso previo antes de bloquear la pantalla.
VITE_IDLE_WARNING_SECONDS=60
